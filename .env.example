# Managed by scripts/bootstrap-env.sh and scripts/bootstrap-storage.sh
# Copy to .env before first use.

# Required: Nebius project + subnet (bootstrap-env.sh will fill these)
PROJECT_ID=project-xxxxxxxxxxxxxxxx
SUBNET_ID=subnet-xxxxxxxxxxxxxxxx
NEBIUS_REGION=eu-north1

# Object storage (bootstrap-storage.sh will fill these)
BUCKET_NAME=
BUCKET_ID=
S3_BUCKET=
S3_PREFIX=cookbook
S3_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud

# AWS-style credentials for Nebius Object Storage (filled by bootstrap-storage.sh)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north1

# Optional: example/user-specific values (not filled by the toolkit)
HF_TOKEN=
